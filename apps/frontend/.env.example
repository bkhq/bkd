# ──────────────────────────────────────────────
# Vite Dev Server
# ──────────────────────────────────────────────
# VITE_DEV_PORT=3000         # Dev server port (default: 3000)
# VITE_DEV_HOST=0.0.0.0      # Dev server host (default: 0.0.0.0)

# ──────────────────────────────────────────────
# API Proxy
# ──────────────────────────────────────────────
# VITE_API_PORT=3010          # API server port for dev proxy & terminal WebSocket (default: 3010)

# ──────────────────────────────────────────────
# Security
# ──────────────────────────────────────────────
# VITE_ALLOWED_HOSTS=          # Comma-separated additional allowed hosts for dev server (default: localhost, 127.0.0.1)
