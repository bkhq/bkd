# ──────────────────────────────────────────────
# Server
# ──────────────────────────────────────────────
# HOST=0.0.0.0              # Listen address (default: 0.0.0.0)
# PORT=3000                  # Listen port (default: 3000)
# ROOT_DIR=                  # Workspace root directory (default: auto-detected from binary/source location)

# SERVER_NAME=                # Instance display name shown in page title (default: BKD)
# SERVER_URL=                 # External base URL for webhooks and copy-link (e.g. https://bkd.example.com)

# ──────────────────────────────────────────────
# Authentication (OIDC + PKCE)
# ──────────────────────────────────────────────
# AUTH_ENABLED=true                     # Master toggle (default: false)
# AUTH_ISSUER=https://accounts.google.com  # OIDC issuer URL (auto-discovers endpoints)
# AUTH_CLIENT_ID=                       # OAuth client ID
# AUTH_CLIENT_SECRET=                   # OAuth client secret
# AUTH_ALLOWED_USERS=alice,bob          # Comma-separated username whitelist
# AUTH_PKCE=true                        # Enable PKCE (default: true)
# AUTH_SECRET=                          # HMAC key for JWT signing (auto-generated if missing)
# AUTH_SCOPES=openid profile email      # OAuth scopes (default: openid profile email)
# AUTH_USERNAME_FIELD=                  # Userinfo field for whitelist (auto-detected by issuer)
# AUTH_SESSION_TTL=604800               # JWT expiry in seconds (default: 7 days)

# ──────────────────────────────────────────────
# Security
# ──────────────────────────────────────────────
# API_SECRET=                # Bearer token for API auth (unset = no auth, dev mode)
# ALLOWED_ORIGIN=*           # CORS allowed origin (default: *)

# ──────────────────────────────────────────────
# Database
# ──────────────────────────────────────────────
# DB_PATH=data/db/bkd.db    # SQLite database path (default: data/db/bkd.db)

# ──────────────────────────────────────────────
# Logging
# ──────────────────────────────────────────────
# LOG_LEVEL=info              # trace | debug | info | warn | error | fatal (compiled binary default: info, dev default: debug)
# SERVICE_NAME=bkd           # Logger name prefix (default: bkd)
# LOG_EXECUTOR_IO=1           # Log executor stdin/stdout (default: 1, set 0 to disable)

# ──────────────────────────────────────────────
# Engine
# ──────────────────────────────────────────────
# MAX_CONCURRENT_EXECUTIONS=5 # Max parallel AI sessions (default: 5)

# ──────────────────────────────────────────────
# AI Provider Keys (auto-detected from env or ~/.config)
# ──────────────────────────────────────────────
# ANTHROPIC_API_KEY=          # Claude API key
# OPENAI_API_KEY=             # OpenAI / Codex API key
# CODEX_API_KEY=              # Codex-specific API key (fallback)

# ──────────────────────────────────────────────
# Debug
# ──────────────────────────────────────────────
# ENABLE_RUNTIME_ENDPOINT=true  # Enable /api/runtime debug endpoint (default: disabled)
