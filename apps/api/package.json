{
  "name": "@bkd/api",
  "type": "module",
  "version": "0.0.6",
  "private": true,
  "description": "Backend API for the Bitk workspace.",
  "homepage": "https://github.com/bkhq",
  "repository": {
    "type": "git",
    "url": "https://github.com/bkhq/bkd.git",
    "directory": "apps/api"
  },
  "module": "src/index.ts",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "start": "NODE_ENV=production bun src/index.ts",
    "test": "bun test --preload ./test/preload.ts test/",
    "test:watch": "bun test --preload ./test/preload.ts --watch test/",
    "db:generate": "bunx drizzle-kit generate",
    "db:migrate": "bunx drizzle-kit migrate"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.16.1",
    "@anthropic-ai/claude-agent-sdk": "~0.2.113",
    "@hono/swagger-ui": "^0.6.1",
    "@hono/zod-openapi": "^1.2.3",
    "@hono/zod-validator": "^0.7.6",
    "consola": "^3.4.2",
    "cronbake": "^0.4.0",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.12.7",
    "jittered-fractional-indexing": "^1.0.1",
    "nanoid": "^5.1.6",
    "pino": "^10.3.1",
    "ulid": "^3.0.2",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@bkd/tsconfig": "workspace:*",
    "drizzle-kit": "^0.31.9",
    "@libsql/client": "^0.17.0",
    "@types/bun": "^1.3.11",
    "typescript": "catalog:"
  }
}
